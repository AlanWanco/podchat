{
  "name": "pomchat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder --publish never",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.441",
    "@remotion/renderer": "^4.0.441",
    "ass-compiler": "^0.1.16",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.441",
    "wavesurfer.js": "^7.12.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.alanwanco.pomchat",
    "productName": "PomChat",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/remotion-worker.cjs",
      "package.json"
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.video",
      "target": [
        "zip",
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "AudioVideo"
    }
  }
}
